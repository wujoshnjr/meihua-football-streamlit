# GitHub案例庫與報告寫回
GITHUB_TOKEN = "github_pat_你的Contents讀寫Token"
GITHUB_REPO = "wujoshnjr/meihua-football-streamlit"
GITHUB_BRANCH = "main"
GITHUB_CASES_PATH = "data/meihua_cases.csv"
GITHUB_REPORTS_DIR = "reports"

# GitHub Models 免費AI
GITHUB_MODELS_TOKEN = "github_pat_你的Models唯讀Token"
AI_ENABLED = true
AI_PROVIDER = "github_models"
AI_MODEL = "openai/gpt-4.1-mini"
# 可指定較強的模型負責第一階段語義盲解；留空或刪除此行則沿用 AI_MODEL
AI_DELIBERATION_MODEL = "openai/gpt-4.1-mini"
AI_TOP_K_CASES = 5
AI_MAX_OUTPUT_TOKENS = 3200
AI_TEMPERATURE = 0.2
AI_REQUIRE_CONFIRMATION = true

# 選用保護
MAX_CASEBOOK_ROWS_FOR_AI = 500
REQUEST_TIMEOUT_SECONDS = 45
